{
  "name": "escrow-lite",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "db:migrate": "bun migrations/migrate.ts",
    "db:create": "bun migrations/create.ts",
    "db:rollback": "bun migrations/rollback.ts",
    "cf:dev": "wrangler dev --assets=./dist",
    "cf:deploy": "wrangler deploy",
    "deploy": "astro build && bun scripts/write-assetsignore.ts && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@better-auth/kysely-adapter": "^1.5.5",
    "astro": "^6.0.5",
    "better-auth": "^1.0.0",
    "kysely": "^0.28.12",
    "kysely-d1": "^0.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.40.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "happy-dom": "^20.8.4",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "vitest-environment-miniflare": "^2.14.4"
  }
}
