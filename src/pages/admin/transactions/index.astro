---
/**
 * Admin Transactions List Page
 *
 * Shows all transactions across all sellers with advanced filtering
 * Admin-only access
 */
import AdminLayout from '@/layouts/AdminLayout.astro';
import TransactionTable from '@/components/admin/TransactionTable.astro';
import { verifyAdminPage } from '@/lib/admin-auth';

export const prerender = false;

// Verify admin authentication
const admin = await verifyAdminPage(Astro);

// Redirect if not authenticated as admin
if (!admin) {
  return Astro.redirect('/login');
}

// Get query parameters from URL
const url = new URL(Astro.request.url);
const sellerIdParam = url.searchParams.get('seller_id') || undefined;
const statusParam = url.searchParams.get('status') || undefined;
const startDateParam = url.searchParams.get('start_date') || undefined;
const endDateParam = url.searchParams.get('end_date') || undefined;
const searchParam = url.searchParams.get('search') || undefined;
const pageParam = url.searchParams.get('page');
const page = pageParam ? parseInt(pageParam, 10) : 1;

let transactions: any[] = [];
let total = 0;
let limit = 50;
let error: string | null = null;

try {
  // Build query parameters for API
  const queryParams = new URLSearchParams();
  if (sellerIdParam) queryParams.append('seller_id', sellerIdParam);
  if (statusParam) queryParams.append('status', statusParam);
  if (startDateParam) queryParams.append('start_date', startDateParam);
  if (endDateParam) queryParams.append('end_date', endDateParam);
  if (searchParam) queryParams.append('search', searchParam);
  queryParams.append('page', page.toString());
  queryParams.append('limit', limit.toString());

  // Fetch from admin API
  const apiUrl = `/admin/api/transactions?${queryParams.toString()}`;
  const response = await fetch(apiUrl);

  if (!response.ok) {
    const errorData = await response.json();
    throw new Error(errorData.error?.message || 'Failed to load transactions');
  }

  const data = await response.json();
  transactions = data.data.transactions;
  total = data.data.pagination.total;
  limit = data.data.pagination.limit;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load transactions';
  console.error('Error fetching transactions:', e);
}

const totalPages = Math.ceil(total / limit);
const hasPrevPage = page > 1;
const hasNextPage = page < totalPages;

const statusOptions = [
  { value: '', label: 'All Statuses' },
  { value: 'pending', label: 'Pending Payment' },
  { value: 'funded', label: 'Funded' },
  { value: 'held', label: 'Held' },
  { value: 'released', label: 'Released' },
  { value: 'disputed', label: 'Disputed' },
  { value: 'refunded', label: 'Refunded' },
  { value: 'expired', label: 'Expired' },
];
---

<AdminLayout title="Transactions - Admin Panel">
  <div class="transactions-page">
    <div class="page-header">
      <h1>All Transactions</h1>
      <p class="subtitle">Manage and monitor all escrow transactions across all sellers</p>
    </div>

    {error ? (
      <div class="error-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span>{error}</span>
      </div>
    ) : (
      <>
        {/* Filters Bar */}
        <div class="filters-bar">
          <form id="filterForm" class="filter-form" method="GET">
            <div class="filter-row">
              <div class="filter-group">
                <label for="status">Status:</label>
                <select id="status" name="status" class="filter-select">
                  {statusOptions.map((option) => (
                    <option
                      value={option.value}
                      selected={statusParam === option.value}
                    >
                      {option.label}
                    </option>
                  ))}
                </select>
              </div>

              <div class="filter-group">
                <label for="search">Search:</label>
                <input
                  type="text"
                  id="search"
                  name="search"
                  class="filter-input"
                  placeholder="Transaction ID, seller email, or buyer email"
                  value={searchParam || ''}
                />
              </div>

              <div class="filter-group">
                <label for="seller_id">Seller ID:</label>
                <input
                  type="text"
                  id="seller_id"
                  name="seller_id"
                  class="filter-input"
                  placeholder="Seller ID"
                  value={sellerIdParam || ''}
                />
              </div>
            </div>

            <div class="filter-row">
              <div class="filter-group">
                <label for="start_date">Start Date:</label>
                <input
                  type="date"
                  id="start_date"
                  name="start_date"
                  class="filter-input"
                  value={startDateParam || ''}
                />
              </div>

              <div class="filter-group">
                <label for="end_date">End Date:</label>
                <input
                  type="date"
                  id="end_date"
                  name="end_date"
                  class="filter-input"
                  value={endDateParam || ''}
                />
              </div>

              <div class="filter-actions">
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                  </svg>
                  Apply Filters
                </button>

                {(sellerIdParam || statusParam || startDateParam || endDateParam || searchParam) && (
                  <a href="/admin/transactions" class="btn btn-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                      <path d="M3 3v5h5"></path>
                    </svg>
                    Reset
                  </a>
                )}
              </div>
            </div>
          </form>

          <div class="results-count">
            {total === 0 ? (
              <span>No transactions found</span>
            ) : (
              <span>
                Showing {transactions.length} of {total} transactions
                (Page {page} of {totalPages})
              </span>
            )}
          </div>
        </div>

        {/* Transactions Table */}
        <div class="table-container">
          <TransactionTable transactions={transactions} />
        </div>

        {/* Empty State */}
        {transactions.length === 0 && (
          <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            <h2>{searchParam || sellerIdParam ? 'No transactions found' : 'No transactions yet'}</h2>
            <p>
              {searchParam || sellerIdParam
                ? 'Try adjusting your filters or search criteria'
                : 'Transactions will appear here once sellers create them'}
            </p>
          </div>
        )}

        {/* Pagination */}
        {transactions.length > 0 && totalPages > 1 && (
          <div class="pagination">
            <div class="pagination-info">
              Page {page} of {totalPages} ({total} total)
            </div>

            <div class="pagination-controls">
              {hasPrevPage ? (
                <a
                  href={`/admin/transactions?page=${page - 1}${statusParam ? `&status=${statusParam}` : ''}${searchParam ? `&search=${encodeURIComponent(searchParam)}` : ''}${sellerIdParam ? `&seller_id=${sellerIdParam}` : ''}${startDateParam ? `&start_date=${startDateParam}` : ''}${endDateParam ? `&end_date=${endDateParam}` : ''}`}
                  class="pagination-btn"
                >
                  ← Previous
                </a>
              ) : (
                <span class="pagination-btn disabled">← Previous</span>
              )}

              <div class="pagination-pages">
                {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                  let pageNum;
                  if (totalPages <= 5) {
                    pageNum = i + 1;
                  } else if (page <= 3) {
                    pageNum = i + 1;
                  } else if (page >= totalPages - 2) {
                    pageNum = totalPages - 4 + i;
                  } else {
                    pageNum = page - 2 + i;
                  }

                  return (
                    <a
                      href={`/admin/transactions?page=${pageNum}${statusParam ? `&status=${statusParam}` : ''}${searchParam ? `&search=${encodeURIComponent(searchParam)}` : ''}${sellerIdParam ? `&seller_id=${sellerIdParam}` : ''}${startDateParam ? `&start_date=${startDateParam}` : ''}${endDateParam ? `&end_date=${endDateParam}` : ''}`}
                      class={`pagination-page ${pageNum === page ? 'active' : ''}`}
                    >
                      {pageNum}
                    </a>
                  );
                })}
              </div>

              {hasNextPage ? (
                <a
                  href={`/admin/transactions?page=${page + 1}${statusParam ? `&status=${statusParam}` : ''}${searchParam ? `&search=${encodeURIComponent(searchParam)}` : ''}${sellerIdParam ? `&seller_id=${sellerIdParam}` : ''}${startDateParam ? `&start_date=${startDateParam}` : ''}${endDateParam ? `&end_date=${endDateParam}` : ''}`}
                  class="pagination-btn"
                >
                  Next →
                </a>
              ) : (
                <span class="pagination-btn disabled">Next →</span>
              )}
            </div>
          </div>
        )}
      </>
    )}
  </div>
</AdminLayout>

<style>
  .transactions-page {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem 0;
  }

  .subtitle {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
  }

  .error-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 0.5rem;
    color: #991b1b;
    margin-bottom: 2rem;
  }

  .filters-bar {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .filter-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .filter-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
    min-width: 200px;
  }

  .filter-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
  }

  .filter-select,
  .filter-input {
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .filter-select:focus,
  .filter-input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .filter-input {
    width: 100%;
  }

  .filter-actions {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-primary {
    background-color: #2563eb;
    color: white;
  }

  .btn-primary:hover {
    background-color: #1d4ed8;
  }

  .btn-secondary {
    background-color: #6b7280;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #4b5563;
  }

  .results-count {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.5rem;
  }

  .table-container {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
  }

  .empty-state svg {
    color: #9ca3af;
    margin-bottom: 1.5rem;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 0.5rem 0;
  }

  .empty-state p {
    color: #6b7280;
    margin: 0;
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    margin-top: 1.5rem;
  }

  .pagination-info {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .pagination-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pagination-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    transition: all 0.15s;
  }

  .pagination-btn:hover:not(.disabled) {
    background-color: #f3f4f6;
    border-color: #9ca3af;
  }

  .pagination-btn.disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .pagination-pages {
    display: flex;
    gap: 0.25rem;
  }

  .pagination-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.5rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    transition: all 0.15s;
  }

  .pagination-page:hover {
    background-color: #f3f4f6;
    border-color: #9ca3af;
  }

  .pagination-page.active {
    background-color: #2563eb;
    border-color: #2563eb;
    color: white;
  }

  @media (max-width: 640px) {
    .pagination {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .pagination-controls {
      flex-wrap: wrap;
      justify-content: center;
    }

    .filter-row {
      flex-direction: column;
    }

    .filter-group {
      min-width: 100%;
    }

    .filter-actions {
      flex-direction: column;
      width: 100%;
    }

    .filter-actions .btn {
      width: 100%;
    }
  }
</style>
