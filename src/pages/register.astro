---
import Layout from '@/layouts/Layout.astro';

const redirectTo = Astro.url.searchParams.get('redirect') || '/dashboard';
---

<Layout title="Daftar - Escrow Lite">
  <div class="auth-page">
    <section class="auth-shell">
      <div class="auth-aside">
        <span class="eyebrow">Seller onboarding</span>
        <h1>Buat akun dan siapkan payout flow Anda dari awal.</h1>
        <p>
          Setelah daftar, Anda bisa langsung masuk ke dashboard untuk menambah rekening bank,
          memantau saldo, dan mulai menerima transaksi escrow.
        </p>
      </div>

      <div class="auth-card">
        <div class="card-header">
          <h2>Daftar</h2>
          <p>Buat akun seller baru untuk mulai menggunakan Escrow Lite.</p>
        </div>

        <form class="auth-form" id="registerForm" data-redirect={redirectTo}>
          <label class="field">
            <span>Nama</span>
            <input type="text" id="name" name="name" required placeholder="Nama lengkap" autocomplete="name" />
          </label>

          <label class="field">
            <span>Email</span>
            <input type="email" id="email" name="email" required placeholder="nama@email.com" autocomplete="email" />
          </label>

          <label class="field">
            <span>Kata Sandi</span>
            <input type="password" id="password" name="password" required minlength="8" placeholder="Minimal 8 karakter" autocomplete="new-password" />
          </label>

          <p id="registerMessage" class="form-message" hidden></p>

          <button type="submit" class="submit-button">
            <span class="submit-label">Buat Akun</span>
            <span class="submit-loading" hidden>Menyimpan...</span>
          </button>
        </form>

        <p class="card-footer">
          Sudah punya akun? <a href={`/login?redirect=${encodeURIComponent(redirectTo)}`}>Masuk</a>
        </p>
      </div>
    </section>
  </div>

  <style>
    .auth-page {
      min-height: 100vh;
      padding: 1.25rem;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at top left, rgba(16, 185, 129, 0.18), transparent 24%),
        radial-gradient(circle at bottom right, rgba(245, 158, 11, 0.14), transparent 22%),
        linear-gradient(135deg, #08111f 0%, #10263b 45%, #16434f 100%);
    }

    .auth-shell {
      width: min(1100px, 100%);
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(360px, 460px);
      gap: 1.5rem;
    }

    .auth-aside,
    .auth-card {
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
    }

    .auth-aside {
      padding: 2rem;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.04));
      color: white;
    }

    .eyebrow {
      display: inline-flex;
      padding: 0.45rem 0.75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #fde68a;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .auth-aside h1 {
      margin-top: 1rem;
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 1;
      color: white;
    }

    .auth-aside p {
      margin-top: 1rem;
      color: rgba(255, 255, 255, 0.78);
      max-width: 46ch;
    }

    .auth-card {
      padding: 2rem;
      background: rgba(255, 255, 255, 0.97);
      box-shadow: 0 30px 80px -45px rgba(8, 17, 31, 0.75);
    }

    .card-header h2 {
      font-size: 2rem;
      margin-bottom: 0.4rem;
    }

    .card-header p,
    .card-footer {
      color: #64748b;
    }

    .auth-form {
      display: grid;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .field {
      display: grid;
      gap: 0.45rem;
    }

    .field span {
      font-weight: 700;
      font-size: 0.9rem;
      color: #0f172a;
    }

    .field input {
      min-height: 52px;
      border-radius: 16px;
      border: 1px solid #dbe4ee;
      background: #f8fafc;
      padding: 0.85rem 1rem;
      font-size: 0.95rem;
    }

    .field input:focus {
      outline: none;
      border-color: #10b981;
      box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.12);
      background: white;
    }

    .form-message {
      margin: 0;
      padding: 0.8rem 0.9rem;
      border-radius: 14px;
      font-size: 0.9rem;
    }

    .form-message[data-tone='error'] {
      background: #fef2f2;
      color: #b91c1c;
    }

    .form-message[data-tone='success'] {
      background: #ecfdf5;
      color: #047857;
    }

    .submit-button {
      min-height: 52px;
      border-radius: 16px;
      border: none;
      color: white;
      background: linear-gradient(135deg, #10b981 0%, #0f766e 100%);
      font-size: 1rem;
      font-weight: 700;
      box-shadow: 0 18px 38px -26px rgba(16, 185, 129, 0.9);
    }

    .submit-button:disabled {
      opacity: 0.7;
      cursor: wait;
    }

    .card-footer {
      margin-top: 1.25rem;
    }

    @media (max-width: 900px) {
      .auth-shell {
        grid-template-columns: 1fr;
      }

      .auth-aside,
      .auth-card {
        padding: 1.5rem;
      }
    }
  </style>

  <script>
    const form = document.getElementById('registerForm') as HTMLFormElement | null;
    const message = document.getElementById('registerMessage') as HTMLParagraphElement | null;
    const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const submitLabel = submitButton?.querySelector('.submit-label') as HTMLSpanElement | null;
    const submitLoading = submitButton?.querySelector('.submit-loading') as HTMLSpanElement | null;

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form || !submitButton) return;

      if (message) {
        message.hidden = true;
        message.textContent = '';
        message.removeAttribute('data-tone');
      }

      submitButton.disabled = true;
      if (submitLabel) submitLabel.hidden = true;
      if (submitLoading) submitLoading.hidden = false;

      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') || ''),
        email: String(formData.get('email') || ''),
        password: String(formData.get('password') || ''),
      };

      try {
        const response = await fetch('/api/v1/auth/register', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error?.message || result.error || 'Registrasi gagal.');
        }

        if (message) {
          message.dataset.tone = 'success';
          message.textContent = 'Akun berhasil dibuat. Mengarahkan ke dashboard...';
          message.hidden = false;
        }

        window.setTimeout(() => {
          window.location.href = form.dataset.redirect || '/dashboard';
        }, 500);
      } catch (error) {
        if (message) {
          message.dataset.tone = 'error';
          message.textContent = error instanceof Error ? error.message : 'Terjadi kesalahan saat mendaftar.';
          message.hidden = false;
        }
      } finally {
        submitButton.disabled = false;
        if (submitLabel) submitLabel.hidden = false;
        if (submitLoading) submitLoading.hidden = true;
      }
    });
  </script>
</Layout>
