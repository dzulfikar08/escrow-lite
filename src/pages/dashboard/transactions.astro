---
/**
 * Transactions List Page (Simplified)
 *
 * Shows seller's transaction history
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { fetchTransactions } from '@/lib/api-client';

export const prerender = false;

// Get query parameters
const url = new URL(Astro.request.url);
const statusParam = url.searchParams.get('status') || undefined;
const searchParam = url.searchParams.get('search') || undefined;
const pageParam = url.searchParams.get('page');
const page = pageParam ? parseInt(pageParam, 10) : 1;

let transactions: any[] = [];
let total = 0;
let limit = 50;
let error: string | null = null;

try {
  const result = await fetchTransactions({
    status: statusParam,
    search: searchParam,
    page,
    limit,
  });
  transactions = result.transactions;
  total = result.total;
  limit = result.limit;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load transactions';
}

const totalPages = Math.ceil(total / limit);
---

<DashboardLayout title="Transactions">
  <div class="transactions-page">
    <div class="page-header">
      <h1>Transactions</h1>
      <p class="subtitle">Riwayat penjualan Anda</p>
    </div>

    {error && (
      <div class="error-message">
        {error}
      </div>
    )}

    {!error && (
      <>
        <div class="stats-summary">
          <div class="stat-item">
            <span class="stat-label">Total Transaksi</span>
            <span class="stat-value">{total}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Halaman</span>
            <span class="stat-value">{page} dari {totalPages}</span>
          </div>
        </div>

        <div class="transactions-container">
          <div class="transactions-list">
            {transactions.map((tx) => (
              <div class="transaction-item" key={tx.id}>
                <div class="transaction-info">
                  <span class="transaction-id">#{tx.id.slice(0, 8)}</span>
                  <span class="transaction-status">{tx.status}</span>
                </div>
                <div class="transaction-details">
                  <span class="transaction-amount">Rp {tx.amount.toLocaleString('id-ID')}</span>
                  <span class="transaction-email">{tx.buyer_email}</span>
                </div>
                <div class="transaction-actions">
                  <a href={`/dashboard/transactions/${tx.id}`} class="btn-view">
                    Lihat Detail
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        {totalPages > 1 && (
          <div class="pagination">
            {page > 1 && (
              <a href={`/dashboard/transactions?page=${page - 1}`} class="pagination-link">
                ← Sebelumnya
              </a>
            )}
            <span class="pagination-info">
              Halaman {page} dari {totalPages}
            </span>
            {page < totalPages && (
              <a href={`/dashboard/transactions?page=${page + 1}`} class="pagination-link">
                Selanjutnya →
              </a>
            )}
          </div>
        )}
      </>
    )}
  </div>
</DashboardLayout>

<style>
  .transactions-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #111827;
  }

  .subtitle {
    color: #6b7280;
  }

  .stats-summary {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: white;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
  }

  .transactions-container {
    background: white;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }

  .transactions-list {
    display: flex;
    flex-direction: column;
  }

  .transaction-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .transaction-item:last-child {
    border-bottom: none;
  }

  .transaction-info {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .transaction-id {
    font-family: monospace;
    font-weight: 600;
    color: #374151;
  }

  .transaction-status {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .transaction-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }

  .transaction-amount {
    font-weight: 600;
    color: #111827;
  }

  .transaction-email {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .btn-view {
    padding: 0.5rem 1rem;
    background: #2563eb;
    color: white;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .btn-view:hover {
    background: #1d4ed8;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem;
  }

  .pagination-link {
    padding: 0.5rem 1rem;
    background: #2563eb;
    color: white;
    border-radius: 0.375rem;
    text-decoration: none;
  }

  .pagination-info {
    color: #6b7280;
  }

  .error-message {
    padding: 1rem;
    background: #fee2e2;
    border: 1px solid #fecaca;
    border-radius: 0.5rem;
    color: #991b1b;
    margin-bottom: 1rem;
  }
</style>
