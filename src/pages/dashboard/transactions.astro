---
/**
 * Transactions List Page (Simplified)
 *
 * Shows seller's transaction history
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';

export const prerender = false;

// Get query parameters
const url = new URL(Astro.request.url);
const statusParam = url.searchParams.get('status') || undefined;
const searchParam = url.searchParams.get('search') || undefined;
const pageParam = url.searchParams.get('page');
const page = pageParam ? parseInt(pageParam, 10) : 1;
const limit = 50;

let transactions: any[] = [];
let total = 0;
let error: string | null = null;

try {
  const queryParams = new URLSearchParams();
  if (statusParam) queryParams.append('status', statusParam);
  if (searchParam) queryParams.append('search', searchParam);
  queryParams.append('page', page.toString());
  queryParams.append('limit', limit.toString());

  const response = await fetch(
    `${Astro.url.origin}/api/v1/seller/transactions?${queryParams.toString()}`,
    {
      headers: {
        'Cookie': Astro.request.headers.get('cookie') || ''
      }
    }
  );

  if (!response.ok) {
    throw new Error(`Failed to load transactions: ${response.statusText}`);
  }

  const result = await response.json();
  transactions = result.data.transactions;
  total = result.data.total;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load transactions';
}

const totalPages = Math.ceil(total / limit);
---

<DashboardLayout title="Transactions">
  <div class="transactions-page">
    <div class="page-header">
      <h1>Transactions</h1>
      <p class="subtitle">Riwayat penjualan Anda</p>
    </div>

    {error && (
      <div class="error-message">
        {error}
      </div>
    )}

    {!error && (
      <>
        <div class="stats-summary">
          <div class="stat-item">
            <span class="stat-label">Total Transaksi</span>
            <span class="stat-value">{total}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Halaman</span>
            <span class="stat-value">{page} dari {totalPages}</span>
          </div>
        </div>

        <div class="transactions-container">
          <div class="transactions-list">
            {transactions.map((tx) => (
              <div class="transaction-item" key={tx.id}>
                <div class="transaction-info">
                  <span class="transaction-id">#{tx.id.slice(0, 8)}</span>
                  <span class="transaction-status">{tx.status}</span>
                </div>
                <div class="transaction-details">
                  <span class="transaction-amount">Rp {tx.amount.toLocaleString('id-ID')}</span>
                  <span class="transaction-email">{tx.buyer_email}</span>
                </div>
                <div class="transaction-actions">
                  <a href={`/dashboard/transactions/${tx.id}`} class="btn-view">
                    Lihat Detail
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        {totalPages > 1 && (
          <div class="pagination">
            {page > 1 && (
              <a href={`/dashboard/transactions?page=${page - 1}`} class="pagination-link">
                ← Sebelumnya
              </a>
            )}
            <span class="pagination-info">
              Halaman {page} dari {totalPages}
            </span>
            {page < totalPages && (
              <a href={`/dashboard/transactions?page=${page + 1}`} class="pagination-link">
                Selanjutnya →
              </a>
            )}
          </div>
        )}
      </>
    )}
  </div>
</DashboardLayout>

<style>
  .transactions-page {
    max-width: 1400px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: #0a1628;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: #64748b;
    font-size: 1rem;
  }

  .stats-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: white;
    border-radius: 1rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 3px rgba(10, 22, 40, 0.05);
    transition: all 0.3s ease;
  }

  .stat-item:hover {
    box-shadow: 0 4px 12px rgba(10, 22, 40, 0.08);
    transform: translateY(-2px);
  }

  .stat-label {
    font-size: 0.8125rem;
    color: #64748b;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: #0a1628;
    letter-spacing: -0.02em;
  }

  .transactions-container {
    background: white;
    border-radius: 1rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 3px rgba(10, 22, 40, 0.05);
    overflow: hidden;
  }

  .transactions-list {
    display: flex;
    flex-direction: column;
  }

  .transaction-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid #f1f5f9;
    transition: all 0.2s ease;
  }

  .transaction-item:hover {
    background: #f8fafc;
  }

  .transaction-item:last-child {
    border-bottom: none;
  }

  .transaction-info {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .transaction-id {
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    font-weight: 700;
    color: #0a1628;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    padding: 0.375rem 0.75rem;
    background: #f1f5f9;
    border-radius: 0.5rem;
  }

  .transaction-status {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .transaction-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }

  .transaction-amount {
    font-weight: 700;
    color: #0a1628;
    font-size: 1rem;
    font-family: var(--font-display);
  }

  .transaction-email {
    font-size: 0.875rem;
    color: #64748b;
  }

  .btn-view {
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
    color: white;
    border-radius: 0.625rem;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(14, 165, 233, 0.25);
    font-family: var(--font-display);
  }

  .btn-view:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(14, 165, 233, 0.35);
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    padding: 1.5rem;
  }

  .pagination-link {
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border-radius: 0.625rem;
    text-decoration: none;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(16, 185, 129, 0.25);
    transition: all 0.3s ease;
    font-family: var(--font-display);
  }

  .pagination-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
  }

  .pagination-info {
    color: #64748b;
    font-weight: 500;
  }

  .error-message {
    padding: 1.25rem;
    background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
    border: 1px solid #fecaca;
    border-radius: 0.75rem;
    color: #991b1b;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .transaction-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .transaction-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .btn-view {
      width: 100%;
      text-align: center;
    }

    .stats-summary {
      grid-template-columns: 1fr;
    }
  }
</style>
