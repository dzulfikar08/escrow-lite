---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { formatDateTime, formatRupiah, getStatusLabel } from '@/lib/api-client';
import type { SellerBalances, Transaction } from '@/lib/api-client';

export const prerender = false;

const defaultBalance: SellerBalances = {
  held_balance: 0,
  available_balance: 0,
  pending_payouts: 0,
  total_paid_out: 0,
};

let balance = defaultBalance;
let recentTransactions: Transaction[] = [];
let totalTransactions = 0;
let loadError: string | null = null;

try {
  const headers = {
    Cookie: Astro.request.headers.get('cookie') || '',
  };

  const [balanceResponse, transactionResponse] = await Promise.all([
    fetch(`${Astro.url.origin}/api/v1/seller/balance`, { headers }),
    fetch(`${Astro.url.origin}/api/v1/seller/transactions?limit=5&page=1`, { headers }),
  ]);

  if (!balanceResponse.ok || !transactionResponse.ok) {
    throw new Error('Dashboard data gagal dimuat.');
  }

  const balanceResult = await balanceResponse.json();
  const transactionResult = await transactionResponse.json();

  balance = balanceResult.data;
  recentTransactions = transactionResult.data.transactions;
  totalTransactions = transactionResult.data.total;
} catch (error) {
  loadError = error instanceof Error ? error.message : 'Dashboard data gagal dimuat.';
}

const stats = [
  {
    title: 'Saldo Ditahan',
    value: formatRupiah(balance.held_balance),
    description: 'Dana dari transaksi yang masih dalam escrow.',
    tone: 'held',
  },
  {
    title: 'Saldo Tersedia',
    value: formatRupiah(balance.available_balance),
    description: 'Dana yang siap diajukan ke payout.',
    tone: 'available',
  },
  {
    title: 'Payout Diproses',
    value: formatRupiah(balance.pending_payouts),
    description: 'Permintaan pencairan yang sedang berjalan.',
    tone: 'pending',
  },
  {
    title: 'Total Transaksi',
    value: totalTransactions.toString(),
    description: 'Total transaksi seller yang tercatat.',
    tone: 'transactions',
  },
];
---

<DashboardLayout title="Dashboard - Escrow Lite">
  <div class="dashboard-page">
    <section class="hero-panel">
      <div>
        <span class="eyebrow">Ringkasan seller</span>
        <h2>Semua hal penting untuk operasional escrow harian Anda.</h2>
        <p>
          Pantau dana tertahan, dana siap cair, dan transaksi terbaru tanpa perlu berpindah-pindah
          halaman.
        </p>
      </div>

      <div class="hero-actions">
        <a href="/dashboard/transactions" class="btn btn-primary">Lihat Transaksi</a>
        <a href="/dashboard/payouts" class="btn btn-secondary">Ajukan Payout</a>
        <a href="/dashboard/settings" class="btn btn-secondary">Kelola Rekening</a>
      </div>
    </section>

    {loadError && <p class="error-banner">{loadError}</p>}

    <section class="stats-grid">
      {stats.map((stat) => (
        <article class={`stat-card stat-card--${stat.tone}`}>
          <p class="stat-label">{stat.title}</p>
          <strong class="stat-value">{stat.value}</strong>
          <p class="stat-description">{stat.description}</p>
        </article>
      ))}
    </section>

    <section class="content-grid">
      <article class="content-card">
        <div class="section-header">
          <div>
            <span class="eyebrow eyebrow-muted">Flow utama</span>
            <h3>Langkah cepat seller</h3>
          </div>
        </div>

        <div class="action-stack">
          <a class="action-card" href="/dashboard/settings">
            <strong>1. Tambah rekening payout</strong>
            <span>Pastikan rekening utama sudah tersimpan sebelum menarik dana.</span>
          </a>
          <a class="action-card" href="/dashboard/transactions">
            <strong>2. Pantau transaksi aktif</strong>
            <span>Lihat status held, disputed, refunded, atau released dalam satu list.</span>
          </a>
          <a class="action-card" href="/dashboard/payouts">
            <strong>3. Cairkan saldo tersedia</strong>
            <span>Ajukan payout saat dana sudah masuk ke saldo available.</span>
          </a>
        </div>
      </article>

      <article class="content-card">
        <div class="section-header">
          <div>
            <span class="eyebrow eyebrow-muted">Transaksi terbaru</span>
            <h3>Aktivitas terkini</h3>
          </div>
          <a href="/dashboard/transactions" class="section-link">Lihat semua</a>
        </div>

        {recentTransactions.length === 0 ? (
          <div class="empty-state">
            <strong>Belum ada transaksi.</strong>
            <p>Begitu transaksi masuk, ringkasannya akan tampil di sini.</p>
          </div>
        ) : (
          <div class="transaction-list">
            {recentTransactions.map((transaction) => (
              <a class="transaction-row" href={`/dashboard/transactions/${transaction.id}`}>
                <div>
                  <strong class="transaction-id">#{transaction.id.slice(0, 8)}</strong>
                  <p class="transaction-meta">{transaction.buyer_email}</p>
                </div>
                <div class="transaction-summary">
                  <span class={`status-pill status-pill--${transaction.status}`}>{getStatusLabel(transaction.status)}</span>
                  <strong>{formatRupiah(transaction.amount)}</strong>
                  <span class="transaction-meta">{formatDateTime(transaction.created_at)}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </article>
    </section>
  </div>
</DashboardLayout>

<style>
  .dashboard-page {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }

  .hero-panel,
  .content-card,
  .stat-card {
    border: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 24px 44px -40px rgba(15, 23, 42, 0.32);
  }

  .hero-panel {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: flex-end;
    padding: 1.75rem;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(16, 185, 129, 0.16), transparent 28%),
      linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: #e2f7ee;
    color: #0f766e;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow-muted {
    background: #eff6ff;
    color: #1d4ed8;
  }

  .hero-panel h2 {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4vw, 3rem);
    max-width: 13ch;
  }

  .hero-panel p {
    margin-top: 0.8rem;
    max-width: 60ch;
    color: #64748b;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    font-weight: 700;
  }

  .btn-primary {
    background: linear-gradient(135deg, #0a1628 0%, #14465f 100%);
    color: white;
  }

  .btn-secondary {
    background: white;
    color: #0a1628;
    border: 1px solid #dbe4ee;
  }

  .error-banner {
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: #fef2f2;
    color: #b91c1c;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .stat-card {
    padding: 1.25rem;
    border-radius: 22px;
    background: white;
  }

  .stat-card--held { background: linear-gradient(135deg, #fff7ed 0%, #fef3c7 100%); }
  .stat-card--available { background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); }
  .stat-card--pending { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); }
  .stat-card--transactions { background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%); }

  .stat-label {
    margin: 0;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #475569;
    font-weight: 700;
  }

  .stat-value {
    display: block;
    margin-top: 0.75rem;
    font-size: 1.75rem;
    color: #0f172a;
  }

  .stat-description {
    margin: 0.65rem 0 0;
    color: #64748b;
    font-size: 0.88rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1rem;
  }

  .content-card {
    padding: 1.4rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(12px);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .section-link {
    font-weight: 700;
    color: #0f766e;
  }

  .action-stack,
  .transaction-list {
    display: grid;
    gap: 0.85rem;
  }

  .action-card,
  .transaction-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border-radius: 18px;
    background: white;
    border: 1px solid #e2e8f0;
  }

  .action-card {
    flex-direction: column;
  }

  .action-card strong,
  .transaction-row strong {
    color: #0f172a;
  }

  .action-card span,
  .transaction-meta,
  .empty-state p {
    color: #64748b;
    font-size: 0.9rem;
  }

  .transaction-row {
    align-items: center;
  }

  .transaction-id {
    display: block;
  }

  .transaction-summary {
    display: grid;
    justify-items: end;
    gap: 0.35rem;
  }

  .status-pill {
    display: inline-flex;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #e2e8f0;
    color: #334155;
  }

  .status-pill--held { background: #fef3c7; color: #b45309; }
  .status-pill--released { background: #d1fae5; color: #047857; }
  .status-pill--disputed { background: #fee2e2; color: #b91c1c; }
  .status-pill--refunded { background: #e2e8f0; color: #475569; }
  .status-pill--funded { background: #dbeafe; color: #1d4ed8; }
  .status-pill--pending { background: #fef3c7; color: #b45309; }

  .empty-state {
    padding: 1rem;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
  }

  @media (max-width: 1024px) {
    .stats-grid,
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-panel,
    .stats-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .hero-panel {
      flex-direction: column;
      align-items: flex-start;
    }

    .transaction-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .transaction-summary {
      justify-items: start;
    }
  }
</style>
