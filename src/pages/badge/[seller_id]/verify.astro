---
/**
 * Public Verification Page
 *
 * Public page showing seller verification details and transaction history
 * Route: /badge/[seller_id]/verify
 */
import BadgeWidget from '@/components/badge/BadgeWidget.astro';
import { calculateSellerStats, formatRupiah, formatDate } from '@/lib/badge/stats';
import { getDb } from '@/db/client';

const sellerId = Astro.params.seller_id as string;

try {
  const db = getDb(Astro.locals.runtime.env);

  // Calculate seller statistics
  const stats = await calculateSellerStats(db, sellerId);

  // Get recent transactions for verification
  const recentTransactions = await db
    .prepare(
      `SELECT
        id,
        buyer_email,
        amount,
        status,
        created_at,
        released_at
       FROM transactions
       WHERE seller_id = ?
       ORDER BY created_at DESC
       LIMIT 20`
    )
    .bind(sellerId)
    .all();

  // Get seller details
  const seller = await db
    .prepare(
      `SELECT
        id,
        name,
        kyc_tier,
        kyc_verified_at,
        created_at
       FROM sellers
       WHERE id = ?`
    )
    .bind(sellerId)
    .first();

  if (!seller) {
    throw new Error('Seller not found');
  }

  // Calculate additional stats
  const successfulReleases = recentTransactions.results.filter(
    (t: any) => t.status === 'released' || t.status === 'paid_out'
  ).length;

  const totalVolume = recentTransactions.results.reduce(
    (sum: number, t: any) => sum + (t.amount || 0),
    0
  );
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verification - {seller.name} | Escrow Lite</title>
    <meta name="description" content={`Verify ${seller.name} on Escrow Lite - ${stats.totalTransactions} transactions with ${stats.successRate}% success rate`} />
  </head>
  <body>
    <div class="verification-page">
      <!-- Header -->
      <header class="page-header">
        <div class="header-content">
          <div class="logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span class="logo-text">Escrow Lite</span>
          </div>
          <div class="header-links">
            <a href="https://escrow-lite.id" target="_blank" rel="noopener noreferrer">
              Visit Escrow Lite
            </a>
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Seller Info Section -->
        <section class="seller-section">
          <div class="seller-header">
            <div class="seller-info">
              <h1 class="seller-name">{seller.name}</h1>
              <p class="seller-badge">
                {stats.kycVerified && (
                  <span class="verified-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                      <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    Verified Seller
                  </span>
                )}
                <span class="kyc-tier">KYC Level: {stats.kycTier.toUpperCase()}</span>
              </p>
            </div>
            <div class="widget-preview">
              <BadgeWidget
                stats={stats}
                theme="light"
                size="medium"
                color="blue"
                showRating={true}
                showStats={true}
                clickable={false}
              />
            </div>
          </div>

          <!-- Stats Grid -->
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon stat-icon--transactions">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              </div>
              <div class="stat-content">
                <p class="stat-label">Total Transactions</p>
                <p class="stat-value">{stats.totalTransactions}</p>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon stat-icon--success">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div class="stat-content">
                <p class="stat-label">Success Rate</p>
                <p class="stat-value">{stats.successRate}%</p>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon stat-icon--volume">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"></line>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
              </div>
              <div class="stat-content">
                <p class="stat-label">Total Volume</p>
                <p class="stat-value">{formatRupiah(stats.totalAmount)}</p>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon stat-icon--calendar">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div class="stat-content">
                <p class="stat-label">Member Since</p>
                <p class="stat-value">{formatDate(stats.memberSince)}</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Recent Transactions -->
        <section class="transactions-section">
          <h2 class="section-title">Recent Transactions</h2>
          <div class="transactions-list">
            {recentTransactions.results.length > 0 ? (
              recentTransactions.results.map((txn: any) => (
                <div class="transaction-row">
                  <div class="transaction-info">
                    <p class="transaction-id">{txn.id}</p>
                    <p class="transaction-date">{formatDate(txn.created_at)}</p>
                  </div>
                  <div class="transaction-amount">
                    {formatRupiah(txn.amount)}
                  </div>
                  <div class="transaction-status">
                    <span class={`status-badge status-${txn.status}`}>
                      {txn.status.toUpperCase()}
                    </span>
                  </div>
                </div>
              ))
            ) : (
              <div class="empty-state">
                <p>No transactions yet</p>
              </div>
            )}
          </div>
        </section>

        <!-- What is Escrow Lite -->
        <section class="info-section">
          <h2 class="section-title">What is Escrow Lite?</h2>
          <div class="info-content">
            <p>
              Escrow Lite is a secure payment platform that protects both buyers and sellers
              in online transactions. When you buy from a seller using Escrow Lite:
            </p>
            <ul class="feature-list">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Your payment is held securely until you receive your order
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Sellers are verified and their reputation is tracked
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Disputes are handled fairly by our team
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Refunds are available if the order is not as described
              </li>
            </ul>
          </div>
        </section>
      </main>

      <!-- Footer -->
      <footer class="page-footer">
        <p>&copy; {new Date().getFullYear()} Escrow Lite. All rights reserved.</p>
        <p>
          <a href="https://escrow-lite.id/terms" target="_blank" rel="noopener noreferrer">Terms of Service</a>
          {' · '}
          <a href="https://escrow-lite.id/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
      'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    line-height: 1.6;
    color: #111827;
    background-color: #f9fafb;
  }

  .verification-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Header */
  .page-header {
    background-color: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 0;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #2563eb;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .header-links a {
    color: #6b7280;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .header-links a:hover {
    color: #2563eb;
  }

  /* Main Content */
  .main-content {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Seller Section */
  .seller-section {
    background-color: white;
    border-radius: 0.75rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .seller-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .seller-info {
    flex: 1;
  }

  .seller-name {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.5rem;
  }

  .seller-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background-color: #d1fae5;
    color: #065f46;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .kyc-tier {
    padding: 0.375rem 0.75rem;
    background-color: #dbeafe;
    color: #1e40af;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background-color: #f9fafb;
    border-radius: 0.5rem;
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .stat-icon--transactions {
    background-color: #dbeafe;
    color: #2563eb;
  }

  .stat-icon--success {
    background-color: #d1fae5;
    color: #059669;
  }

  .stat-icon--volume {
    background-color: #fef3c7;
    color: #d97706;
  }

  .stat-icon--calendar {
    background-color: #f3f4f6;
    color: #4b5563;
  }

  .stat-content {
    flex: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
  }

  /* Transactions Section */
  .transactions-section {
    background-color: white;
    border-radius: 0.75rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 1.5rem;
  }

  .transactions-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .transaction-row {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: 1rem;
    padding: 1rem;
    background-color: #f9fafb;
    border-radius: 0.5rem;
    align-items: center;
  }

  .transaction-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .transaction-id {
    font-weight: 600;
    color: #111827;
    font-size: 0.875rem;
  }

  .transaction-date {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .transaction-amount {
    font-weight: 600;
    color: #111827;
    font-size: 0.875rem;
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    text-align: center;
  }

  .status-released,
  .status-paid_out {
    background-color: #d1fae5;
    color: #065f46;
  }

  .status-held,
  .status-funded {
    background-color: #fef3c7;
    color: #92400e;
  }

  .status-disputed {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .status-refunded {
    background-color: #f3f4f6;
    color: #374151;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: #9ca3af;
  }

  /* Info Section */
  .info-section {
    background-color: white;
    border-radius: 0.75rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .info-content p {
    color: #4b5563;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .feature-list {
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: #4b5563;
  }

  .feature-list svg {
    color: #059669;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  /* Footer */
  .page-footer {
    background-color: white;
    border-top: 1px solid #e5e7eb;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .page-footer p {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }

  .page-footer a {
    color: #2563eb;
    text-decoration: none;
  }

  .page-footer a:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .seller-header {
      flex-direction: column;
    }

    .widget-preview {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .transaction-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .transaction-status {
      text-align: left;
    }
  }
</style>
---
} catch (error) {
  // Error handling
  const errorMessage = error instanceof Error ? error.message : 'Unknown error';
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verification Error | Escrow Lite</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background-color: #fef2f2;
        color: #111827;
      }

      .error-container {
        text-align: center;
        max-width: 400px;
        padding: 2rem;
      }

      .error-icon {
        width: 64px;
        height: 64px;
        color: #dc2626;
        margin-bottom: 1rem;
      }

      .error-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #991b1b;
        margin-bottom: 0.5rem;
      }

      .error-message {
        font-size: 1rem;
        color: #b91c1c;
        margin-bottom: 1.5rem;
      }

      .error-link {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        background-color: #2563eb;
        color: white;
        text-decoration: none;
        border-radius: 0.375rem;
        font-weight: 500;
        transition: background-color 0.2s;
      }

      .error-link:hover {
        background-color: #1d4ed8;
      }
    </style>
  </head>
  <body>
    <div class="error-container">
      <svg class="error-icon" xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="15" y1="9" x2="9" y2="15"></line>
        <line x1="9" y1="9" x2="15" y2="15"></line>
      </svg>
      <h1 class="error-title">Verification Failed</h1>
      <p class="error-message">{errorMessage}</p>
      <a href="https://escrow-lite.id" class="error-link">Return to Escrow Lite</a>
    </div>
  </body>
</html>
---
}
