---
import type { AdminUser } from '@/lib/admin-auth';

interface Props {
  adminUser: AdminUser;
}

const { adminUser } = Astro.props;
const roleBadgeColor = adminUser.role === 'super_admin' ? 'purple' : 'blue';
const roleLabel = adminUser.role === 'super_admin' ? 'Super Admin' : 'Admin';
---

<header class="admin-header">
  <div class="header-left">
    <button class="mobile-menu-toggle" id="adminMobileMenuToggle" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <div class="header-title">
      <h1>Admin Panel</h1>
      <span class={`role-badge role-badge--${roleBadgeColor}`}>{roleLabel}</span>
    </div>
  </div>

  <div class="header-right">
    <div class="admin-info">
      <div class="admin-avatar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <div class="admin-details">
        <span class="admin-name">{adminUser.name}</span>
        <span class="admin-email">{adminUser.email}</span>
      </div>
    </div>

    <form action="/api/v1/auth/logout" method="POST" class="logout-form" id="adminLogoutForm">
      <button type="submit" class="logout-button" aria-label="Logout">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        <span>Keluar</span>
      </button>
    </form>
  </div>
</header>

<style>
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 10px 26px -24px rgba(15, 23, 42, 0.35);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(12px);
  }

  .header-left,
  .header-right,
  .header-title,
  .admin-info {
    display: flex;
    align-items: center;
  }

  .header-left {
    gap: 1rem;
  }

  .header-right {
    gap: 1.5rem;
  }

  .header-title {
    gap: 0.75rem;
  }

  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: #374151;
    border-radius: 0.375rem;
  }

  .header-title h1 {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .role-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .role-badge--purple {
    background-color: #f3e8ff;
    color: #7c3aed;
  }

  .role-badge--blue {
    background-color: #dbeafe;
    color: #2563eb;
  }

  .admin-info {
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background-color: #f9fafb;
    border-radius: 0.75rem;
    border: 1px solid #e5e7eb;
  }

  .admin-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: #e5e7eb;
    color: #6b7280;
    border-radius: 50%;
  }

  .admin-details {
    display: flex;
    flex-direction: column;
  }

  .admin-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #111827;
  }

  .admin-email {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .logout-form {
    margin: 0;
  }

  .logout-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .admin-header {
      padding: 1rem;
    }

    .mobile-menu-toggle {
      display: block;
    }

    .admin-details,
    .logout-button span {
      display: none;
    }

    .logout-button {
      padding: 0.7rem;
    }
  }
</style>

<script>
  const adminLogoutForm = document.getElementById('adminLogoutForm') as HTMLFormElement | null;

  adminLogoutForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const response = await fetch(adminLogoutForm.action, {
      method: 'POST',
    });

    if (response.ok) {
      window.location.href = '/login';
    }
  });
</script>
