---
/**
 * DisputeList Component
 * Displays a list of disputes with filtering and pagination
 */

interface Dispute {
  id: string;
  transaction_id: string;
  reason_category: string;
  status: string;
  resolution: string | null;
  created_at: string;
  updated_at: string;
  buyer_email: string;
  seller_name: string;
  amount: number;
}

interface Props {
  disputes: Dispute[];
  total: number;
  page: number;
  limit: number;
  currentStatus?: string;
}

const { disputes, total, page, limit, currentStatus = 'all' } = Astro.props;

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
  }).format(amount);
};

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('id-ID', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};

const getStatusColor = (status: string) => {
  const colors = {
    open: 'bg-yellow-100 text-yellow-800',
    seller_responding: 'bg-blue-100 text-blue-800',
    under_review: 'bg-purple-100 text-purple-800',
    resolved: 'bg-green-100 text-green-800',
    closed: 'bg-gray-100 text-gray-800',
  };
  return colors[status as keyof typeof colors] || 'bg-gray-100 text-gray-800';
};

const getStatusLabel = (status: string) => {
  const labels = {
    open: 'Open',
    seller_responding: 'Seller Responding',
    under_review: 'Under Review',
    resolved: 'Resolved',
    closed: 'Closed',
  };
  return labels[status as keyof typeof labels] || status;
};

const getResolutionLabel = (resolution: string | null) => {
  if (!resolution) return '-';
  const labels = {
    released_to_seller: 'Seller Favored',
    refunded_to_buyer: 'Buyer Favored',
    partial: 'Partial',
    rejected: 'Rejected',
  };
  return labels[resolution as keyof typeof labels] || resolution;
};

const totalPages = Math.ceil(total / limit);
---

<div class="dispute-list">
  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-600">Total Disputes</div>
      <div class="text-2xl font-bold">{total}</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow mb-6 p-4">
    <form method="get" class="flex flex-wrap gap-4 items-center">
      <div>
        <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
        <select
          id="status"
          name="status"
          class="block w-48 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2"
        >
          <option value="all" selected={currentStatus === 'all'}>All Status</option>
          <option value="open" selected={currentStatus === 'open'}>Open</option>
          <option value="seller_responding" selected={currentStatus === 'seller_responding'}>
            Seller Responding
          </option>
          <option value="under_review" selected={currentStatus === 'under_review'}>
            Under Review
          </option>
          <option value="resolved" selected={currentStatus === 'resolved'}>Resolved</option>
          <option value="closed" selected={currentStatus === 'closed'}>Closed</option>
        </select>
      </div>
      <div class="flex-1"></div>
      <button
        type="submit"
        class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
      >
        Apply Filters
      </button>
    </form>
  </div>

  <!-- Disputes Table -->
  <div class="bg-white shadow overflow-hidden rounded-md">
    {disputes.length === 0 ? (
      <div class="text-center py-12">
        <svg
          class="mx-auto h-12 w-12 text-gray-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No disputes</h3>
        <p class="mt-1 text-sm text-gray-500">No disputes found with the current filters.</p>
      </div>
    ) : (
      <>
        <ul class="divide-y divide-gray-200">
          {disputes.map((dispute) => (
            <li>
              <a
                href={`/admin/disputes/${dispute.id}`}
                class="block hover:bg-gray-50 transition duration-150 ease-in-out"
              >
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between">
                        <p class="text-sm font-medium text-indigo-600 truncate">
                          Transaction #{dispute.transaction_id.slice(0, 8)}
                        </p>
                        <div class="ml-2 flex-shrink-0 flex">
                          <span
                            class={"px-2 inline-flex text-xs leading-5 font-semibold rounded-full " +
                              getStatusColor(dispute.status)}
                          >
                            {getStatusLabel(dispute.status)}
                          </span>
                        </div>
                      </div>
                      <div class="mt-2 sm:flex sm:justify-between">
                        <div class="sm:flex">
                          <p class="flex items-center text-sm text-gray-500 mr-6">
                            <svg
                              class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                              />
                            </svg>
                            {dispute.buyer_email}
                          </p>
                          <p class="flex items-center text-sm text-gray-500 mr-6">
                            <svg
                              class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                              />
                            </svg>
                            {dispute.seller_name}
                          </p>
                          <p class="flex items-center text-sm text-gray-500">
                            <svg
                              class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                              />
                            </svg>
                            {formatCurrency(dispute.amount)}
                          </p>
                        </div>
                        <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                          <svg
                            class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            />
                          </svg>
                          <p>{formatDate(dispute.created_at)}</p>
                        </div>
                      </div>
                      {dispute.resolution && (
                        <div class="mt-2">
                          <span class="text-xs text-gray-500">
                            Resolution: <strong>{getResolutionLabel(dispute.resolution)}</strong>
                          </span>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
            <div class="flex items-center justify-between">
              <div class="flex-1 flex justify-between sm:hidden">
                {page > 1 && (
                  <a
                    href={`?page=${page - 1}&status=${currentStatus}`}
                    class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                  >
                    Previous
                  </a>
                )}
                {page < totalPages && (
                  <a
                    href={`?page=${page + 1}&status=${currentStatus}`}
                    class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                  >
                    Next
                  </a>
                )}
              </div>
              <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm text-gray-700">
                    Showing
                    <span class="font-medium">{(page - 1) * limit + 1}</span>
                    to
                    <span class="font-medium">{Math.min(page * limit, total)}</span>
                    of
                    <span class="font-medium">{total}</span>
                    results
                  </p>
                </div>
                <div>
                  <nav
                    class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px"
                    aria-label="Pagination"
                  >
                    {page > 1 && (
                      <a
                        href={`?page=${page - 1}&status=${currentStatus}`}
                        class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                      >
                        Previous
                      </a>
                    )}
                    {Array.from({ length: totalPages }, (_, i) => i + 1)
                      .filter(
                        (p) =>
                          p === 1 ||
                          p === totalPages ||
                          (p >= page - 1 && p <= page + 1)
                      )
                      .map((p, i, arr) => {
                        const showEllipsis =
                          i > 0 &&
                          arr[i - 1] !== undefined &&
                          p !== arr[i - 1]! + 1;
                        return (
                          <>
                            {showEllipsis && (
                              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
                                ...
                              </span>
                            )}
                            <a
                              href={`?page=${p}&status=${currentStatus}`}
                              class={
                                p === page
                                  ? 'relative inline-flex items-center px-4 py-2 border border-indigo-500 bg-indigo-50 text-sm font-medium text-indigo-600'
                                  : 'relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50'
                              }
                            >
                              {p}
                            </a>
                          </>
                        );
                      })}
                    {page < totalPages && (
                      <a
                        href={`?page=${page + 1}&status=${currentStatus}`}
                        class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                      >
                        Next
                      </a>
                    )}
                  </nav>
                </div>
              </div>
            </div>
          </div>
        )}
      </>
    )}
  </div>
</div>

<style>
  .dispute-list {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
