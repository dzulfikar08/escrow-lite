---
/**
 * StatusBadge Component
 *
 * Color-coded status indicator for transactions
 */
import { getStatusColor, getStatusLabel } from '@/lib/api-client';

interface Props {
  status: string;
}

const { status } = Astro.props;

const colorClass = getStatusColor(status);
const label = getStatusLabel(status);
---

<span class={`status-badge ${colorClass}`}>
  {label}
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
  }

  .bg-yellow-100 {
    background-color: #fef3c7;
  }

  .text-yellow-800 {
    color: #92400e;
  }

  .bg-blue-100 {
    background-color: #dbeafe;
  }

  .text-blue-800 {
    color: #1e40af;
  }

  .bg-purple-100 {
    background-color: #f3e8ff;
  }

  .text-purple-800 {
    color: #6b21a8;
  }

  .bg-green-100 {
    background-color: #dcfce7;
  }

  .text-green-800 {
    color: #166534;
  }

  .bg-emerald-100 {
    background-color: #d1fae5;
  }

  .text-emerald-800 {
    color: #065f46;
  }

  .bg-red-100 {
    background-color: #fee2e2;
  }

  .text-red-800 {
    color: #991b1b;
  }

  .bg-gray-100 {
    background-color: #f3f4f6;
  }

  .text-gray-800 {
    color: #1f2937;
  }

  .bg-indigo-100 {
    background-color: #e0e7ff;
  }

  .text-indigo-800 {
    color: #3730a3;
  }

  .bg-orange-100 {
    background-color: #ffedd5;
  }

  .text-orange-800 {
    color: #9a3412;
  }
</style>
