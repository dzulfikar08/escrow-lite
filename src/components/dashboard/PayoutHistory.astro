---
/**
 * PayoutHistory Component
 *
 * Displays list of past payouts with status badges
 */
import { formatRupiah, formatDateTime, getStatusColor, getStatusLabel } from '@/lib/api-client';

interface Payout {
  id: string;
  amount: number;
  fee_amount: number;
  net_amount: number;
  status: string;
  bank_code: string;
  account_number: string;
  account_name: string;
  disbursement_ref?: string;
  failed_reason?: string;
  requested_at: string;
  processing_at?: string;
  completed_at?: string;
}

interface Props {
  payouts: Payout[];
}

const { payouts } = Astro.props;

// Status labels specific to payouts
const getPayoutStatusLabel = (status: string): string => {
  const labels: Record<string, string> = {
    pending: 'Menunggu',
    processing: 'Diproses',
    completed: 'Berhasil',
    failed: 'Gagal',
    cancelled: 'Dibatalkan'
  };
  return labels[status] || status;
};

const getPayoutStatusColor = (status: string): string => {
  const colors: Record<string, string> = {
    pending: 'badge-yellow',
    processing: 'badge-blue',
    completed: 'badge-green',
    failed: 'badge-red',
    cancelled: 'badge-gray'
  };
  return colors[status] || 'badge-gray';
};
---

<div class="payout-history">
  <div class="history-header">
    <h3>Riwayat Pencairan</h3>
    <p class="history-subtitle">Daftar penarikan dana yang sudah diajukan</p>
  </div>

  {
    payouts.length > 0 ? (
      <div class="payout-list">
        {
          payouts.map((payout) => (
            <div class="payout-item">
              <div class="payout-main">
                <div class="payout-amount">
                  <p class="amount-text">{formatRupiah(payout.net_amount)}</p>
                  <p class="fee-text">Biaya: {formatRupiah(payout.fee_amount)}</p>
                </div>

                <div class="payout-info">
                  <div class="bank-info">
                    <span class="bank-code">{payout.bank_code}</span>
                    <span class="account-number">
                      ****{payout.account_number.slice(-4)}
                    </span>
                    <span class="account-name">{payout.account_name}</span>
                  </div>

                  <div class="payout-dates">
                    <p class="date-text">
                      Diajukan: {formatDateTime(payout.requested_at)}
                    </p>
                    {
                      payout.completed_at && (
                        <p class="date-text">
                          Selesai: {formatDateTime(payout.completed_at)}
                        </p>
                      )
                    }
                  </div>

                  {
                    payout.failed_reason && (
                      <p class="error-text">
                        Alasan gagal: {payout.failed_reason}
                      </p>
                    )
                  }

                  {
                    payout.disbursement_ref && (
                      <p class="ref-text">
                        Ref: {payout.disbursement_ref}
                      </p>
                    )
                  }
                </div>
              </div>

              <div class="payout-status">
                <span class={`status-badge ${getPayoutStatusColor(payout.status)}`}>
                  {getPayoutStatusLabel(payout.status)}
                </span>
              </div>
            </div>
          ))
        }
      </div>
    ) : (
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
        </svg>
        <p class="empty-text">Belum ada riwayat pencairan</p>
        <p class="empty-hint">Dana yang Anda tarik akan muncul di sini</p>
      </div>
    )
  }
</div>

<style>
  .payout-history {
    background: white;
    border-radius: 0.75rem;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
  }

  .history-header {
    margin-bottom: 1.5rem;
  }

  .history-header h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.25rem;
  }

  .history-subtitle {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .payout-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .payout-item {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    transition: border-color 0.2s ease;
  }

  .payout-item:hover {
    border-color: #d1d5db;
  }

  .payout-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .payout-amount {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .amount-text {
    font-size: 1.125rem;
    font-weight: 700;
    color: #111827;
  }

  .fee-text {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .payout-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bank-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bank-code {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
  }

  .account-number {
    font-size: 0.875rem;
    color: #6b7280;
    font-family: 'Courier New', monospace;
  }

  .account-name {
    font-size: 0.875rem;
    color: #374151;
  }

  .payout-dates {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .date-text {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .error-text {
    font-size: 0.75rem;
    color: #dc2626;
    font-weight: 500;
  }

  .ref-text {
    font-size: 0.75rem;
    color: #6b7280;
    font-family: 'Courier New', monospace;
  }

  .payout-status {
    flex-shrink: 0;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: #9ca3af;
  }

  .empty-state svg {
    margin: 0 auto 1rem;
    opacity: 0.5;
  }

  .empty-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }

  .empty-hint {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  /* Status badge color variants */
  .badge-yellow { background-color: #fef3c7; color: #92400e; }
  .badge-blue   { background-color: #dbeafe; color: #1e40af; }
  .badge-green  { background-color: #dcfce7; color: #166534; }
  .badge-red    { background-color: #fee2e2; color: #991b1b; }
  .badge-gray   { background-color: #f3f4f6; color: #1f2937; }

  @media (max-width: 768px) {
    .payout-item {
      flex-direction: column;
    }

    .payout-status {
      align-self: flex-start;
    }
  }
</style>
