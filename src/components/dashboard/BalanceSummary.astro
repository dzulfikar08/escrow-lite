---
/**
 * BalanceSummary Component
 *
 * Displays balance cards showing held, available, pending, and paid out amounts
 */
import { formatRupiah } from '@/lib/api-client';

interface BalanceCard {
  title: string;
  amount: number;
  icon: string;
  color: string;
  description: string;
}

interface Props {
  heldBalance: number;
  availableBalance: number;
  pendingPayouts: number;
  totalPaidOut: number;
}

const { heldBalance, availableBalance, pendingPayouts, totalPaidOut } = Astro.props;

const balances: BalanceCard[] = [
  {
    title: 'Dana Ditahan',
    amount: heldBalance,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`,
    color: 'purple',
    description: 'Dana dari transaksi yang sedang berjalan'
  },
  {
    title: 'Saldo Tersedia',
    amount: availableBalance,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>`,
    color: 'green',
    description: 'Dana yang bisa ditarik kapan saja'
  },
  {
    title: 'Pencairan Diproses',
    amount: pendingPayouts,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
    color: 'yellow',
    description: 'Sedang diproses oleh sistem'
  },
  {
    title: 'Total Ditarik',
    amount: totalPaidOut,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>`,
    color: 'blue',
    description: 'Total penarikan yang sudah berhasil'
  }
];

function getColorClasses(color: string) {
  const colors = {
    purple: {
      bg: 'color-purple',
      icon: 'icon-purple',
      text: 'text-purple'
    },
    green: {
      bg: 'color-green',
      icon: 'icon-green',
      text: 'text-green'
    },
    yellow: {
      bg: 'color-yellow',
      icon: 'icon-yellow',
      text: 'text-yellow'
    },
    blue: {
      bg: 'color-blue',
      icon: 'icon-blue',
      text: 'text-blue'
    }
  };
  return colors[color as keyof typeof colors] || colors.blue;
}
---

<div class="balance-summary">
  <div class="summary-header">
    <h2>Ringkasan Saldo</h2>
    <p class="summary-subtitle">Pantau saldo dan dana Anda di Escrow Lite</p>
  </div>

  <div class="balance-cards">
    {
      balances.map((balance) => {
        const colors = getColorClasses(balance.color);
        return (
          <div class={`balance-card ${colors.bg}`}>
            <div class={`card-icon ${colors.icon}`}>
              <div set:html={balance.icon} />
            </div>
            <div class="card-content">
              <p class={`card-title ${colors.text}`}>{balance.title}</p>
              <p class={`card-amount ${colors.text}`}>{formatRupiah(balance.amount)}</p>
              <p class="card-description">{balance.description}</p>
            </div>
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .balance-summary {
    margin-bottom: 2.5rem;
  }

  .summary-header {
    margin-bottom: 2rem;
  }

  .summary-header h2 {
    font-size: 1.875rem;
    font-weight: 800;
    color: #0a1628;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .summary-subtitle {
    font-size: 0.9375rem;
    color: #64748b;
    font-weight: 400;
  }

  .balance-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .balance-card {
    border-radius: 1.25rem;
    padding: 1.75rem;
    display: flex;
    gap: 1.25rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .balance-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--card-color) 0%, var(--card-color-light) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .balance-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.15);
  }

  .balance-card:hover::before {
    opacity: 1;
  }

  .card-icon {
    flex-shrink: 0;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .card-icon::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    background: var(--card-color);
    opacity: 0.15;
    transition: opacity 0.3s ease;
  }

  .balance-card:hover .card-icon::after {
    opacity: 0.25;
  }

  .card-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.9;
  }

  .card-amount {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    word-break: break-word;
    letter-spacing: -0.02em;
    font-family: var(--font-display);
  }

  .card-description {
    font-size: 0.8125rem;
    color: #64748b;
    line-height: 1.5;
    font-weight: 400;
  }

  /* Color variants */
  .color-purple {
    --card-color: #9333ea;
    --card-color-light: #a855f7;
    background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%);
  }
  .color-purple .card-icon { color: #9333ea; background: #f3e8ff; }
  .color-purple .card-title { color: #7c3aed; }
  .color-purple .card-amount { color: #6b21a8; }

  .color-green {
    --card-color: #10b981;
    --card-color-light: #34d399;
    background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  }
  .color-green .card-icon { color: #10b981; background: #d1fae5; }
  .color-green .card-title { color: #059669; }
  .color-green .card-amount { color: #047857; }

  .color-yellow {
    --card-color: #f59e0b;
    --card-color-light: #fbbf24;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  }
  .color-yellow .card-icon { color: #f59e0b; background: #fef3c7; }
  .color-yellow .card-title { color: #d97706; }
  .color-yellow .card-amount { color: #b45309; }

  .color-blue {
    --card-color: #0ea5e9;
    --card-color-light: #38bdf8;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  }
  .color-blue .card-icon { color: #0ea5e9; background: #e0f2fe; }
  .color-blue .card-title { color: #0284c7; }
  .color-blue .card-amount { color: #0369a1; }

  @media (max-width: 768px) {
    .balance-cards {
      grid-template-columns: 1fr;
    }

    .summary-header h2 {
      font-size: 1.5rem;
    }
  }
</style>
