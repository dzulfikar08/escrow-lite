---
interface Props {
  seller: {
    name: string;
    email: string;
    businessName: string;
  };
}

const { seller } = Astro.props;
---

<header class="dashboard-header">
  <div class="header-left">
    <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <h1 class="header-title">{seller.businessName}</h1>
  </div>

  <div class="header-right">
    <div class="seller-info">
      <span class="seller-name">{seller.name}</span>
      <span class="seller-email">{seller.email}</span>
    </div>

    <form action="/api/auth/logout" method="POST" class="logout-form">
      <button type="submit" class="logout-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Keluar
      </button>
    </form>
  </div>
</header>

<style>
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2.5rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #e2e8f0;
    box-shadow: 0 1px 3px rgba(10, 22, 40, 0.05);
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .mobile-menu-toggle {
    display: none;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    cursor: pointer;
    padding: 0.625rem;
    color: #0a1628;
    border-radius: 0.625rem;
    transition: all 0.3s ease;
  }

  .mobile-menu-toggle:hover {
    background: #f1f5f9;
    transform: scale(1.05);
  }

  .header-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0a1628;
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .seller-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding: 0.5rem 1rem;
    background: #f8fafc;
    border-radius: 0.625rem;
    border: 1px solid #e2e8f0;
  }

  .seller-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #0a1628;
    font-family: var(--font-display);
  }

  .seller-email {
    font-size: 0.75rem;
    color: #64748b;
  }

  .logout-form {
    margin: 0;
  }

  .logout-button {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(239, 68, 68, 0.25);
    font-family: var(--font-display);
  }

  .logout-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.35);
  }

  .logout-button svg {
    width: 16px;
    height: 16px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .dashboard-header {
      padding: 1rem 1.5rem;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .header-title {
      font-size: 1.125rem;
    }

    .seller-info {
      display: none;
    }

    .logout-button span {
      display: none;
    }

    .logout-button {
      padding: 0.625rem;
    }

    .header-right {
      gap: 1rem;
    }
  }
</style>

<script>
  const mobileMenuToggle = document.getElementById('mobileMenuToggle');
  const navigation = document.querySelector('.dashboard-navigation');

  mobileMenuToggle?.addEventListener('click', () => {
    navigation?.classList.toggle('mobile-open');
  });
</script>
