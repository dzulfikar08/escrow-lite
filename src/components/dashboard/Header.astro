---
interface Props {
  seller: {
    name: string;
    email: string;
    businessName: string;
  };
}

const { seller } = Astro.props;
---

<header class="dashboard-header">
  <div class="header-left">
    <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <h1 class="header-title">{seller.businessName}</h1>
  </div>

  <div class="header-right">
    <div class="seller-info">
      <span class="seller-name">{seller.name}</span>
      <span class="seller-email">{seller.email}</span>
    </div>

    <form action="/api/auth/logout" method="POST" class="logout-form">
      <button type="submit" class="logout-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Keluar
      </button>
    </form>
  </div>
</header>

<style>
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: white;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: #374151;
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }

  .mobile-menu-toggle:hover {
    background-color: #f3f4f6;
  }

  .header-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    margin: 0;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .seller-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .seller-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
  }

  .seller-email {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .logout-form {
    margin: 0;
  }

  .logout-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: #ef4444;
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .logout-button:hover {
    background-color: #dc2626;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .dashboard-header {
      padding: 1rem;
    }

    .mobile-menu-toggle {
      display: block;
    }

    .header-title {
      font-size: 1rem;
    }

    .seller-info {
      display: none;
    }

    .logout-button span {
      display: none;
    }

    .logout-button {
      padding: 0.5rem;
    }
  }
</style>

<script>
  const mobileMenuToggle = document.getElementById('mobileMenuToggle');
  const navigation = document.querySelector('.dashboard-navigation');

  mobileMenuToggle?.addEventListener('click', () => {
    navigation?.classList.toggle('mobile-open');
  });
</script>
