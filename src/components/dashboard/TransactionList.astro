---
/**
 * TransactionList Component
 *
 * Table-based display for desktop transaction list
 */
import StatusBadge from './StatusBadge.astro';
import type { Transaction } from '@/lib/api-client';
import { formatRupiah, formatDate } from '@/lib/api-client';

interface Props {
  transactions: Transaction[];
}

const { transactions } = Astro.props;

const hasTransactions = transactions && transactions.length > 0;
---

<div class="transaction-list-container">
  <div class="table-wrapper">
    <table class="transaction-table">
      <thead>
        <tr>
          <th>ID Transaksi</th>
          <th>Pembeli</th>
          <th>Jumlah</th>
          <th>Status</th>
          <th>Tanggal</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        {hasTransactions ? (
          transactions.map((transaction) => (
            <tr>
              <td class="transaction-id">
                <code>{transaction.id.slice(0, 12)}...</code>
              </td>
              <td class="buyer-email">{transaction.buyer_email}</td>
              <td class="amount">{formatRupiah(transaction.amount)}</td>
              <td class="status">
                <StatusBadge status={transaction.status} />
              </td>
              <td class="date">{formatDate(transaction.created_at)}</td>
              <td class="actions">
                <a href={`/dashboard/transactions/${transaction.id}`} class="view-button">
                  Lihat
                </a>
              </td>
            </tr>
          ))
        ) : (
          <tr>
            <td colspan="6" class="empty-state">
              <div class="empty-content">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                <p>Belum ada transaksi</p>
              </div>
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</div>

<style>
  .transaction-list-container {
    width: 100%;
  }

  .table-wrapper {
    overflow-x: auto;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background: white;
  }

  .transaction-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .transaction-table thead {
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }

  .transaction-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #374151;
    white-space: nowrap;
  }

  .transaction-table tbody tr {
    border-bottom: 1px solid #e5e7eb;
    transition: background-color 0.15s;
  }

  .transaction-table tbody tr:hover {
    background-color: #f9fafb;
  }

  .transaction-table tbody tr:last-child {
    border-bottom: none;
  }

  .transaction-table td {
    padding: 0.75rem 1rem;
  }

  .transaction-id code {
    font-family: monospace;
    font-size: 0.8125rem;
    color: #374151;
    background: #f3f4f6;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
  }

  .buyer-email {
    color: #6b7280;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .amount {
    font-weight: 600;
    color: #111827;
  }

  .date {
    color: #6b7280;
    white-space: nowrap;
  }

  .view-button {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background-color: #2563eb;
    color: white;
    text-decoration: none;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    transition: background-color 0.15s;
  }

  .view-button:hover {
    background-color: #1d4ed8;
  }

  .empty-state {
    padding: 3rem 1rem;
    text-align: center;
  }

  .empty-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #9ca3af;
  }

  .empty-content svg {
    width: 48px;
    height: 48px;
  }

  .empty-content p {
    margin: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .transaction-table {
      font-size: 0.8125rem;
    }

    .transaction-table th,
    .transaction-table td {
      padding: 0.5rem 0.75rem;
    }

    .buyer-email {
      max-width: 150px;
    }
  }
</style>
