---
/**
 * TransactionDetail - Admin transaction detail view
 *
 * Shows comprehensive transaction information including:
 * - Transaction details
 * - Seller information
 * - Buyer information
 * - Ledger entries
 * - Dispute information (if any)
 * - Admin actions
 */
import StatusBadge from '@/components/dashboard/StatusBadge';
import AdminActions from './AdminActions.astro';

interface LedgerEntry {
  id: string;
  type: string;
  amount: number;
  direction: string;
  balance_after: number;
  note?: string;
  created_at: string;
}

interface Dispute {
  id: string;
  initiated_by: string;
  reason_category: string;
  buyer_description?: string;
  seller_response?: string;
  status: string;
  resolution?: string;
  created_at: string;
}

interface Seller {
  id: string;
  name: string;
  email: string;
  kyc_tier: string;
  webhook_url?: string;
}

interface Transaction {
  id: string;
  seller_id: string;
  buyer_email: string;
  buyer_phone?: string;
  amount: number;
  fee_amount: number;
  fee_rate: number;
  net_amount: number;
  status: string;
  gateway?: string;
  gateway_ref?: string;
  payment_method?: string;
  payment_link?: string;
  auto_release_days: number;
  auto_release_at?: string;
  absolute_expire_at: string;
  shipped_at?: string;
  tracking_number?: string;
  courier?: string;
  released_at?: string;
  release_reason?: string;
  refunded_at?: string;
  refund_reason?: string;
  created_at: string;
  updated_at: string;
}

interface Props {
  transaction: Transaction;
  seller: Seller;
  ledgerEntries: LedgerEntry[];
  dispute?: Dispute | null;
  adminRole: 'admin' | 'super_admin';
}

const { transaction, seller, ledgerEntries, dispute, adminRole } = Astro.props;

// Format currency
const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
};

// Format date
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};

// Calculate fee percentage
const feePercentage = (transaction.fee_rate / 100).toFixed(2);
---

<div class="transaction-detail">
  <!-- Header -->
  <div class="detail-header">
    <div class="header-info">
      <h1>Transaction {transaction.id}</h1>
      <StatusBadge status={transaction.status} />
    </div>
    <AdminActions
      transactionId={transaction.id}
      status={transaction.status}
      adminRole={adminRole}
    />
  </div>

  <!-- Main Content Grid -->
  <div class="detail-grid">
    <!-- Transaction Details -->
    <section class="detail-section">
      <h2>Transaction Details</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="label">Status</span>
          <span class="value"><StatusBadge status={transaction.status} /></span>
        </div>
        <div class="info-item">
          <span class="label">Amount</span>
          <span class="value amount">{formatCurrency(transaction.amount)}</span>
        </div>
        <div class="info-item">
          <span class="label">Fee ({feePercentage}%)</span>
          <span class="value fee">{formatCurrency(transaction.fee_amount)}</span>
        </div>
        <div class="info-item">
          <span class="label">Net Amount</span>
          <span class="value net">{formatCurrency(transaction.net_amount)}</span>
        </div>
        <div class="info-item">
          <span class="label">Created</span>
          <span class="value">{formatDate(transaction.created_at)}</span>
        </div>
        <div class="info-item">
          <span class="label">Last Updated</span>
          <span class="value">{formatDate(transaction.updated_at)}</span>
        </div>
        {transaction.auto_release_at && (
          <div class="info-item">
            <span class="label">Auto Release</span>
            <span class="value">{formatDate(transaction.auto_release_at)}</span>
          </div>
        )}
        {transaction.absolute_expire_at && (
          <div class="info-item">
            <span class="label">Expires</span>
            <span class="value">{formatDate(transaction.absolute_expire_at)}</span>
          </div>
        )}
      </div>
    </section>

    <!-- Payment Information -->
    <section class="detail-section">
      <h2>Payment Information</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="label">Gateway</span>
          <span class="value">{transaction.gateway?.toUpperCase() || 'N/A'}</span>
        </div>
        {transaction.gateway_ref && (
          <div class="info-item">
            <span class="label">Gateway Ref</span>
            <span class="value">{transaction.gateway_ref}</span>
          </div>
        )}
        {transaction.payment_method && (
          <div class="info-item">
            <span class="label">Payment Method</span>
            <span class="value">{transaction.payment_method}</span>
          </div>
        )}
        {transaction.payment_link && (
          <div class="info-item">
            <span class="label">Payment Link</span>
            <span class="value">
              <a href={transaction.payment_link} target="_blank" rel="noopener">
                Open Payment Page
              </a>
            </span>
          </div>
        )}
      </div>
    </section>

    <!-- Seller Information -->
    <section class="detail-section">
      <h2>Seller Information</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="label">Name</span>
          <span class="value">{seller.name}</span>
        </div>
        <div class="info-item">
          <span class="label">Email</span>
          <span class="value">{seller.email}</span>
        </div>
        <div class="info-item">
          <span class="label">KYC Tier</span>
          <span class="value">{seller.kyc_tier}</span>
        </div>
        <div class="info-item">
          <span class="label">Seller ID</span>
          <span class="value">{seller.id}</span>
        </div>
      </div>
    </section>

    <!-- Buyer Information -->
    <section class="detail-section">
      <h2>Buyer Information</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="label">Email</span>
          <span class="value">{transaction.buyer_email}</span>
        </div>
        {transaction.buyer_phone && (
          <div class="info-item">
            <span class="label">Phone</span>
            <span class="value">{transaction.buyer_phone}</span>
          </div>
        )}
      </div>
    </section>

    <!-- Shipping Information (if shipped) -->
    {transaction.shipped_at && (
      <section class="detail-section">
        <h2>Shipping Information</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="label">Shipped At</span>
            <span class="value">{formatDate(transaction.shipped_at)}</span>
          </div>
          {transaction.tracking_number && (
            <div class="info-item">
              <span class="label">Tracking Number</span>
              <span class="value">{transaction.tracking_number}</span>
            </div>
          )}
          {transaction.courier && (
            <div class="info-item">
              <span class="label">Courier</span>
              <span class="value">{transaction.courier}</span>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Dispute Information (if any) -->
    {dispute && (
      <section class="detail-section disputed">
        <h2>Dispute Information</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="label">Dispute ID</span>
            <span class="value">{dispute.id}</span>
          </div>
          <div class="info-item">
            <span class="label">Status</span>
            <span class="value">{dispute.status}</span>
          </div>
          <div class="info-item">
            <span class="label">Initiated By</span>
            <span class="value">{dispute.initiated_by}</span>
          </div>
          <div class="info-item">
            <span class="label">Reason</span>
            <span class="value">{dispute.reason_category}</span>
          </div>
          {dispute.buyer_description && (
            <div class="info-item full-width">
              <span class="label">Buyer Description</span>
              <span class="value">{dispute.buyer_description}</span>
            </div>
          )}
          {dispute.seller_response && (
            <div class="info-item full-width">
              <span class="label">Seller Response</span>
              <span class="value">{dispute.seller_response}</span>
            </div>
          )}
          {dispute.resolution && (
            <div class="info-item">
              <span class="label">Resolution</span>
              <span class="value">{dispute.resolution}</span>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Ledger Entries -->
    <section class="detail-section full-width">
      <h2>Ledger Entries</h2>
      <div class="ledger-entries">
        {ledgerEntries.length > 0 ? (
          <table class="ledger-table">
            <thead>
              <tr>
                <th>Type</th>
                <th>Direction</th>
                <th>Amount</th>
                <th>Balance After</th>
                <th>Note</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              {ledgerEntries.map((entry) => (
                <tr>
                  <td>{entry.type}</td>
                  <td>
                    <span class={`direction ${entry.direction}`}>
                      {entry.direction}
                    </span>
                  </td>
                  <td>{formatCurrency(entry.amount)}</td>
                  <td>{formatCurrency(entry.balance_after)}</td>
                  <td>{entry.note || '-'}</td>
                  <td>{formatDate(entry.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p class="empty-state">No ledger entries found</p>
        )}
      </div>
    </section>
  </div>
</div>

<style>
  .transaction-detail {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .header-info h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem 0;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .detail-section {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .detail-section.full-width {
    grid-column: 1 / -1;
  }

  .detail-section.disputed {
    border-color: #fecaca;
    background-color: #fef2f2;
  }

  .detail-section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 1rem 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .info-item.full-width {
    grid-column: 1 / -1;
  }

  .info-item .label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }

  .info-item .value {
    font-size: 0.9375rem;
    color: #111827;
    font-weight: 500;
  }

  .info-item .value a {
    color: #2563eb;
    text-decoration: none;
  }

  .info-item .value a:hover {
    text-decoration: underline;
  }

  .info-item .value.amount {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .info-item .value.fee {
    color: #dc2626;
  }

  .info-item .value.net {
    color: #059669;
    font-size: 1.125rem;
    font-weight: 700;
  }

  .ledger-entries {
    margin-top: 1rem;
  }

  .ledger-table {
    width: 100%;
    border-collapse: collapse;
  }

  .ledger-table thead {
    background-color: #f9fafb;
  }

  .ledger-table th {
    padding: 0.75rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }

  .ledger-table td {
    padding: 0.75rem;
    border-top: 1px solid #e5e7eb;
    font-size: 0.875rem;
  }

  .direction {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .direction.credit {
    background-color: #d1fae5;
    color: #065f46;
  }

  .direction.debit {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .empty-state {
    text-align: center;
    color: #6b7280;
    font-size: 0.9375rem;
    padding: 2rem;
  }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .detail-header {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
