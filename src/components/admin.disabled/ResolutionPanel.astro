---
/**
 * ResolutionPanel Component
 * Form for admins to resolve disputes with outcome selection and notes
 */

interface Props {
  disputeId: string;
  disputeStatus: string;
  canResolve: boolean;
}

const { disputeId, disputeStatus, canResolve } = Astro.props;
---

<div class="resolution-panel">
  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Resolve Dispute
      </h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        Review all evidence and information before making a decision.
      </p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      {!canResolve ? (
        <div class="rounded-md bg-yellow-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg
                class="h-5 w-5 text-yellow-400"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-yellow-800">
                Dispute {disputeStatus === 'resolved' ? 'Already Resolved' : 'Cannot Be Resolved'}
              </h3>
              <div class="mt-2 text-sm text-yellow-700">
                <p>
                  {disputeStatus === 'resolved'
                    ? 'This dispute has already been resolved.'
                    : 'This dispute cannot be resolved in its current state.'}
                </p>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <form id="resolve-form" class="space-y-6">
          <input type="hidden" name="dispute_id" value={disputeId} />

          <!-- Resolution Options -->
          <div>
            <label class="block text-sm font-medium text-gray-700">
              Resolution Decision <span class="text-red-500">*</span>
            </label>
            <p class="mt-1 text-xs text-gray-500">
              Select the outcome of this dispute resolution
            </p>
            <div class="mt-4 space-y-3">
              <label class="relative flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input
                  type="radio"
                  name="resolution"
                  value="released_to_seller"
                  required
                  class="h-4 w-4 mt-1 text-indigo-600 border-gray-300 focus:ring-indigo-500"
                />
                <div class="ml-3">
                  <span class="block text-sm font-medium text-gray-900">
                    Release to Seller (Seller Favored)
                  </span>
                  <span class="block text-xs text-gray-500 mt-1">
                    Funds will be released to the seller's available balance
                  </span>
                </div>
              </label>

              <label class="relative flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input
                  type="radio"
                  name="resolution"
                  value="refunded_to_buyer"
                  required
                  class="h-4 w-4 mt-1 text-indigo-600 border-gray-300 focus:ring-indigo-500"
                />
                <div class="ml-3">
                  <span class="block text-sm font-medium text-gray-900">
                    Refund to Buyer (Buyer Favored)
                  </span>
                  <span class="block text-xs text-gray-500 mt-1">
                    Full refund will be processed to the buyer
                  </span>
                </div>
              </label>

              <label class="relative flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input
                  type="radio"
                  name="resolution"
                  value="partial"
                  required
                  class="h-4 w-4 mt-1 text-indigo-600 border-gray-300 focus:ring-indigo-500"
                />
                <div class="ml-3">
                  <span class="block text-sm font-medium text-gray-900">
                    Partial Resolution
                  </span>
                  <span class="block text-xs text-gray-500 mt-1">
                    Split the amount between buyer and seller (requires manual processing)
                  </span>
                </div>
              </label>

              <label class="relative flex items-start p-4 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                <input
                  type="radio"
                  name="resolution"
                  value="rejected"
                  required
                  class="h-4 w-4 mt-1 text-indigo-600 border-gray-300 focus:ring-indigo-500"
                />
                <div class="ml-3">
                  <span class="block text-sm font-medium text-gray-900">
                    Reject Dispute
                  </span>
                  <span class="block text-xs text-gray-500 mt-1">
                    Dispute is rejected and transaction remains in current state
                  </span>
                </div>
              </label>
            </div>
          </div>

          <!-- Resolution Notes -->
          <div>
            <label for="note" class="block text-sm font-medium text-gray-700">
              Resolution Notes <span class="text-red-500">*</span>
            </label>
            <p class="mt-1 text-xs text-gray-500">
              Provide detailed explanation for this resolution decision. This will be visible to both parties.
            </p>
            <div class="mt-2">
              <textarea
                id="note"
                name="note"
                rows={5}
                required
                minlength="10"
                class="shadow-sm block w-full focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border border-gray-300 rounded-md p-3"
                placeholder="Explain the reasoning behind your decision. Include details about evidence reviewed and factors considered..."
              ></textarea>
            </div>
            <p class="mt-2 text-xs text-gray-500">
              Minimum 10 characters. This note will be recorded in the audit log.
            </p>
          </div>

          <!-- Warning Notice -->
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg
                  class="h-5 w-5 text-red-400"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  Important: This action cannot be undone
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <p>
                    Once you submit this resolution, the dispute status will be updated to "resolved" and the transaction will be processed accordingly. This action will be logged in the audit trail.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
            <button
              type="button"
              onclick="history.back()"
              class="inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              Cancel
            </button>
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              Submit Resolution
            </button>
          </div>
        </form>
      )}
    </div>
  </div>
</div>

<style>
  .resolution-panel {
    font-family: system-ui, -apple-system, sans-serif;
  }

  #resolve-form input[type="radio"]:checked + div {
    color: #4f46e5;
  }
</style>

<script>
  const form = document.getElementById('resolve-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const resolution = formData.get('resolution') as string;
    const note = formData.get('note') as string;

    if (!resolution || !note || note.trim().length < 10) {
      alert('Please select a resolution and provide detailed notes (minimum 10 characters).');
      return;
    }

    // Confirm before submitting
    const confirmMsg = `You are about to resolve this dispute with the following decision:\n\n` +
      `Resolution: ${resolution.replace(/_/g, ' ').toUpperCase()}\n` +
      `Note: ${note}\n\n` +
      `This action cannot be undone. Continue?`;

    if (!confirm(confirmMsg)) {
      return;
    }

    // Disable submit button
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    try {
      const response = await fetch(`/admin/api/disputes/${form.dataset.disputeId}/resolve`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          resolution,
          note: note.trim(),
        }),
      });

      const result = await response.json();

      if (response.ok && result.data?.success) {
        alert('Dispute resolved successfully!');
        window.location.href = '/admin/disputes';
      } else {
        alert(`Error: ${result.error?.message || 'Failed to resolve dispute'}`);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Resolution';
      }
    } catch (error) {
      console.error('Error resolving dispute:', error);
      alert('An error occurred while resolving the dispute. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Resolution';
    }
  });
</script>
