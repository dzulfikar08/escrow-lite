---
import { getAuth } from '@/lib/auth';
import Header from '@/components/dashboard/Header.astro';
import Navigation from '@/components/dashboard/Navigation.astro';
import Layout from '@/layouts/Layout.astro';

// Get the current path for active state highlighting
const currentPath = Astro.url.pathname;

// Get the D1 database from runtime
const db = Astro.locals.runtime.env.DB;

// Check authentication
const auth = getAuth(db);
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

// Redirect to login if not authenticated
if (!session) {
  return Astro.redirect('/login');
}

// Mock seller data for now - will be replaced with real data from DB
const seller = {
  id: session.user.id,
  name: session.user.name || 'Penjual',
  email: session.user.email,
  businessName: 'Toko Saya' // Will be fetched from DB later
};

// Pass seller data and current path to components
---

<Layout title="Dashboard - Escrow Lite">
  <div class="dashboard-layout">
    <Navigation currentPath={currentPath} />

    <div class="dashboard-main">
      <Header seller={seller} />

      <main class="dashboard-content">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<style>
  .dashboard-layout {
    display: flex;
    min-height: 100vh;
    background-color: #f5f5f5;
  }

  .dashboard-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    margin-left: 250px; /* Width of sidebar */
  }

  .dashboard-content {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .dashboard-main {
      margin-left: 0;
    }

    .dashboard-content {
      padding: 1rem;
    }
  }
</style>
