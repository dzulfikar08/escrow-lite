---
import { getAuth } from '@/lib/auth';
import { verifyAdminPage } from '@/lib/admin-auth';
import AdminHeader from '@/components/admin/AdminHeader.astro';
import Layout from '@/layouts/Layout.astro';

interface Props {
  title?: string;
}

const { title = 'Admin Panel - Escrow Lite' } = Astro.props;

// Get the current path for active state highlighting
const currentPath = Astro.url.pathname;

// Get the D1 database from runtime
const db = Astro.locals.runtime.env.DB;

// Check authentication
const auth = getAuth(db);
const session = await auth.api.getSession({
  headers: Astro.request.headers
});

// Verify admin access
const adminUser = await verifyAdminPage(Astro);

if (!adminUser) {
  // Not an admin - redirect to seller dashboard
  return Astro.redirect('/dashboard?error=access_denied');
}
---

<Layout title={title}>
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <div class="admin-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span>Escrow Lite</span>
        </div>
        <div class="admin-badge">
          <span class="badge-dot"></span>
          <span class="badge-text">Admin Panel</span>
        </div>
      </div>

      <nav class="admin-navigation">
        <a href="/admin" class={`nav-item ${currentPath === '/admin' ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          <span>Dashboard</span>
        </a>

        <a href="/admin/transactions" class={`nav-item ${currentPath.startsWith('/admin/transactions') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          <span>Transactions</span>
        </a>

        <a href="/admin/disputes" class={`nav-item ${currentPath.startsWith('/admin/disputes') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          <span>Disputes</span>
        </a>

        <a href="/admin/sellers" class={`nav-item ${currentPath.startsWith('/admin/sellers') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <span>Sellers</span>
        </a>

        <a href="/admin/payouts" class={`nav-item ${currentPath.startsWith('/admin/payouts') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
            <line x1="1" y1="10" x2="23" y2="10"></line>
          </svg>
          <span>Payouts</span>
        </a>

        <a href="/admin/audit" class={`nav-item ${currentPath.startsWith('/admin/audit') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
          <span>Audit Log</span>
        </a>

        <div class="nav-divider"></div>

        <a href="/admin/settings" class={`nav-item ${currentPath.startsWith('/admin/settings') ? 'nav-item--active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </svg>
          <span>Settings</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <a href="/dashboard" class="back-to-seller">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Back to Seller Dashboard</span>
        </a>
      </div>
    </aside>

    <div class="admin-main">
      <AdminHeader adminUser={adminUser} />

      <main class="admin-content">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<style>
  .admin-layout {
    display: flex;
    min-height: 100vh;
    background-color: #f9fafb;
  }

  /* Sidebar */
  .admin-sidebar {
    width: 280px;
    background-color: #1f2937;
    color: white;
    display: flex;
    flex-direction: column;
    position: fixed;
    height: 100vh;
    left: 0;
    top: 0;
    overflow-y: auto;
  }

  .sidebar-header {
    padding: 1.5rem;
    border-bottom: 1px solid #374151;
  }

  .admin-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .admin-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background-color: #10b981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Navigation */
  .admin-navigation {
    flex: 1;
    padding: 1rem 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    color: #d1d5db;
    text-decoration: none;
    transition: all 0.2s;
    border-left: 3px solid transparent;
  }

  .nav-item:hover {
    background-color: #374151;
    color: white;
  }

  .nav-item--active {
    background-color: #374151;
    color: white;
    border-left-color: #3b82f6;
  }

  .nav-divider {
    height: 1px;
    background-color: #374151;
    margin: 1rem 1.5rem;
  }

  .sidebar-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid #374151;
  }

  .back-to-seller {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .back-to-seller:hover {
    color: white;
  }

  /* Main Content */
  .admin-main {
    flex: 1;
    margin-left: 280px;
    display: flex;
    flex-direction: column;
  }

  .admin-content {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }

  /* Mobile Responsive */
  @media (max-width: 1024px) {
    .admin-sidebar {
      transform: translateX(-100%);
      transition: transform 0.3s;
      z-index: 50;
    }

    .admin-sidebar.mobile-open {
      transform: translateX(0);
    }

    .admin-main {
      margin-left: 0;
    }

    .admin-content {
      padding: 1rem;
    }
  }
</style>
