---
/**
 * Admin Disputes List Page
 * Displays all disputes with filtering and pagination
 */

import DisputeList from '@/components/admin/DisputeList.astro';
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

// Get query parameters
const url = new URL(Astro.request.url);
const statusParam = url.searchParams.get('status') || 'all';
const pageParam = url.searchParams.get('page') || '1';

let page = parseInt(pageParam, 10);
if (isNaN(page) || page < 1) {
  page = 1;
}

// Check authentication
const session = Astro.locals.session;
if (!session?.user?.id) {
  return Astro.redirect('/login');
}

// Check admin access
const userEmail = session.user.email;
if (!userEmail || !userEmail.includes('admin')) {
  return Astro.redirect('/dashboard');
}

// Fetch disputes from API
const apiUrl = new URL(`${Astro.request.url.origin}/admin/api/disputes`);
apiUrl.searchParams.set('page', page.toString());
if (statusParam !== 'all') {
  apiUrl.searchParams.set('status', statusParam);
}

const response = await fetch(apiUrl.toString());
const result = await response.json();

const disputes = result.data?.disputes || [];
const total = result.data?.total || 0;
const limit = result.data?.limit || 50;
---

<Layout title="Dispute Management - Admin">
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Dispute Management</h1>
            <p class="mt-1 text-sm text-gray-500">
              Review and resolve transaction disputes
            </p>
          </div>
          <div class="flex space-x-3">
            <a
              href="/admin"
              class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
            >
              <svg
                class="mr-2 -ml-1 h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                />
              </svg>
              Admin Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <DisputeList
        disputes={disputes}
        total={total}
        page={page}
        limit={limit}
        currentStatus={statusParam}
      />
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
