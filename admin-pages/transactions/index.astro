---
/**
 * Admin Transactions Page (Simplified)
 *
 * Admin interface for managing all transactions
 */
import AdminLayout from '@/layouts/AdminLayout.astro';

export const prerender = false;

// Get query parameters
const url = new URL(Astro.request.url);
const statusParam = url.searchParams.get('status') || undefined;
const pageParam = url.searchParams.get('page');
const page = pageParam ? parseInt(pageParam, 10) : 1;

// Mock data for now
const transactions = [
  {
    id: 'tx_001',
    seller_id: 'seller_001',
    buyer_email: 'buyer@example.com',
    amount: 150000,
    status: 'held',
    created_at: '2024-01-15T10:00:00Z'
  },
  {
    id: 'tx_002',
    seller_id: 'seller_002',
    buyer_email: 'buyer2@example.com',
    amount: 250000,
    status: 'released',
    created_at: '2024-01-15T11:00:00Z'
  }
];

const total = 100;
const limit = 50;
const totalPages = Math.ceil(total / limit);
---

<AdminLayout title="Transactions">
  <div class="admin-transactions-page">
    <div class="page-header">
      <h1>Transactions</h1>
      <p>Manage all platform transactions</p>
    </div>

    <div class="transactions-table">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Seller</th>
            <th>Buyer Email</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {transactions.map((tx) => (
            <tr key={tx.id}>
              <td>{tx.id}</td>
              <td>{tx.seller_id}</td>
              <td>{tx.buyer_email}</td>
              <td>Rp {tx.amount.toLocaleString('id-ID')}</td>
              <td>{tx.status}</td>
              <td>{new Date(tx.created_at).toLocaleDateString('id-ID')}</td>
              <td>
                <a href={`/admin/transactions/${tx.id}`} class="btn-view">
                  View
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {totalPages > 1 && (
      <div class="pagination">
        {page > 1 && (
          <a href={`/admin/transactions?page=${page - 1}`} class="pagination-link">
            ← Previous
          </a>
        )}
        <span class="pagination-info">
          Page {page} of {totalPages}
        </span>
        {page < totalPages && (
          <a href={`/admin/transactions?page=${page + 1}`} class="pagination-link">
            Next →
          </a>
        )}
      </div>
    )}
  </div>
</AdminLayout>

<style>
  .admin-transactions-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .transactions-table {
    background: white;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .transactions-table table {
    width: 100%;
    border-collapse: collapse;
  }

  .transactions-table th,
  .transactions-table td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }

  .transactions-table th {
    background: #f9fafb;
    font-weight: 600;
    color: #374151;
  }

  .btn-view {
    padding: 0.5rem 1rem;
    background: #2563eb;
    color: white;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem;
  }

  .pagination-link {
    padding: 0.5rem 1rem;
    background: #2563eb;
    color: white;
    border-radius: 0.375rem;
    text-decoration: none;
  }

  .pagination-info {
    color: #6b7280;
  }
</style>
