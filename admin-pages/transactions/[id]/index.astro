---
/**
 * Admin Transaction Detail Page
 *
 * Shows comprehensive transaction details with admin actions
 * Admin-only access
 */
import AdminLayout from '@/layouts/AdminLayout.astro';
import TransactionDetail from '@/components/admin/TransactionDetail.astro';
import { verifyAdminPage } from '@/lib/admin-auth';

export const prerender = false;

// Verify admin authentication
const admin = await verifyAdminPage(Astro);

// Redirect if not authenticated as admin
if (!admin) {
  return Astro.redirect('/login');
}

// Get transaction ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/transactions');
}

let transaction: any = null;
let seller: any = null;
let ledgerEntries: any[] = [];
let dispute: any = null;
let error: string | null = null;

try {
  // Fetch from admin API
  const response = await fetch(`/admin/api/transactions/${id}`);

  if (!response.ok) {
    const errorData = await response.json();
    throw new Error(errorData.error?.message || 'Failed to load transaction');
  }

  const data = await response.json();
  transaction = data.data.transaction;
  seller = data.data.seller;
  ledgerEntries = data.data.ledger_entries;
  dispute = data.data.dispute;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load transaction';
  console.error('Error fetching transaction:', e);
}

// Redirect if transaction not found
if (!transaction && !error) {
  return Astro.redirect('/admin/transactions');
}
---

<AdminLayout title={`Transaction ${id} - Admin Panel`}>
  <div class="transaction-detail-page">
    {error ? (
      <div class="error-container">
        <div class="error-banner">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <div>
            <h2>Error Loading Transaction</h2>
            <p>{error}</p>
          </div>
        </div>

        <a href="/admin/transactions" class="btn btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
          </svg>
          Back to Transactions
        </a>
      </div>
    ) : (
      <>
        <div class="breadcrumb">
          <a href="/admin/transactions">← Back to All Transactions</a>
        </div>

        <TransactionDetail
          transaction={transaction}
          seller={seller}
          ledgerEntries={ledgerEntries}
          dispute={dispute}
          adminRole={admin.role}
        />
      </>
    )}
  </div>
</AdminLayout>

<style>
  .transaction-detail-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .breadcrumb {
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6b7280;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: #2563eb;
  }

  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 4rem 2rem;
  }

  .error-banner {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 2rem;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 0.75rem;
    color: #991b1b;
    max-width: 600px;
  }

  .error-banner svg {
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .error-banner h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
  }

  .error-banner p {
    margin: 0;
    color: #991b1b;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
  }

  .btn-secondary {
    background-color: #6b7280;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #4b5563;
  }

  @media (max-width: 640px) {
    .error-banner {
      flex-direction: column;
      text-align: center;
    }

    .error-banner svg {
      margin-top: 0;
    }
  }
</style>
