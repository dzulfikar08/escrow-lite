  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Create a new seller account"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate and receive session token\n\n**Post-response script:**\n```javascript\nconst cookies = response.headers.toArray().find(h => h[0].toLowerCase() === 'set-cookie');\nif (cookies) {\n  const sessionMatch = cookies[1].match(/session=([^;]+)/);\n  if (sessionMatch) {\n    pm.collectionVariables.set('session_token', sessionMatch[1]);\n  }\n}\n```"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const cookies = pm.response.headers.get('set-cookie');",
                  "if (cookies) {",
                  "  const sessionMatch = cookies.match(/session=([^;]+)/);",
                  "  if (sessionMatch) {",
                  "    pm.collectionVariables.set('session_token', sessionMatch[1]);",
                  "    console.log('Session token saved:', sessionMatch[1]);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{session_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "End current session"
          },
          "response": []
        }
      ],
      "description": "User authentication and session management"
    },
    {
